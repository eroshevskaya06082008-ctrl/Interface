<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="ChatForm">
  <grid id="27dc6" binding="panel1" default-binding="true" layout-manager="GridLayoutManager" row-count="2" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
    <margin top="0" left="0" bottom="0" right="0"/>
    <constraints>
      <xy x="20" y="20" width="500" height="400"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <grid id="3a455" binding="mainPanel" layout-manager="BorderLayout" hgap="0" vgap="0">
        <constraints>
          <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="7" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties/>
        <border type="none"/>
        <children>
          <scrollpane id="f8c4e">
            <constraints border-constraint="Center"/>
            <properties/>
            <border type="none"/>
            <children>
              <component id="c21f1" class="javax.swing.JTextArea" binding="chatArea">
                <constraints/>
                <properties/>
              </component>
            </children>
          </scrollpane>
          <scrollpane id="33c23">
            <constraints border-constraint="East"/>
            <properties/>
            <border type="none"/>
            <children>
              <component id="9e65" class="javax.swing.JList" binding="userList">
                <constraints/>
                <properties/>
              </component>
            </children>
          </scrollpane>
        </children>
      </grid>
      <grid id="81d3" layout-manager="BorderLayout" hgap="0" vgap="0">
        <constraints>
          <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false">
            <preferred-size width="-1" height="60"/>
            <maximum-size width="-1" height="60"/>
          </grid>
        </constraints>
        <properties/>
        <border type="none"/>
        <children>
          <component id="266a8" class="javax.swing.JTextField" binding="messageField">
            <constraints border-constraint="Center"/>
            <properties>
              <maximumSize width="-1" height="40"/>
            </properties>
            <clientProperties>
              <html.disable class="java.lang.Boolean" value="false"/>
            </clientProperties>
          </component>
          <component id="8e60" class="javax.swing.JButton" binding="sendButton">
            <constraints border-constraint="East"/>
            <properties>
              <maximumSize width="-1" height="30"/>
              <text value="Button"/>
            </properties>
          </component>
        </children>
      </grid>
    </children>
  </grid>
</form>
